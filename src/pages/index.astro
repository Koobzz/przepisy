---
import { getCollection } from "astro:content";
import Layout from "../components/Layout.astro";
import RecipeCard from "../components/RecipeCard.astro";
import SearchBox from "../components/SearchBox.astro";
import { allTags, sortedRecipes } from "../lib/recipes";
import { sitePath } from "../lib/urls";

const recipes = sortedRecipes(await getCollection("recipes"));
const tags = allTags(recipes);
---

<Layout title="Przepisy" description="Domowa kolekcja przepisów zapisana w Markdown.">
  <section class="intro">
    <p class="eyebrow">Domowa kolekcja</p>
    <h1>Przepisy</h1>
    <p>Sprawdzone przepisy zapisane jako proste pliki Markdown, gotowe do czytania, drukowania i szybkiego wyszukiwania.</p>
  </section>

  <SearchBox />

  <section class="section">
    <div class="section-heading">
      <h2>Wszystkie przepisy</h2>
      <a href={sitePath("tagi/")}>Zobacz tagi</a>
    </div>
    <div class="recipe-grid">
      {recipes.map((recipe) => <RecipeCard recipe={recipe} />)}
    </div>
  </section>

  {tags.length > 0 && (
    <section class="section">
      <h2>Tagi</h2>
      <ul class="tag-cloud">
        {tags.map(([tag, count]) => (
          <li>
            <a href={sitePath(`tagi/${encodeURIComponent(tag)}/`)}>
              {tag} <span>({count})</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>
